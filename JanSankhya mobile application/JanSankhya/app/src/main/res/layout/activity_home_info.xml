<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout android:layout_width="match_parent" android:layout_height="6dp" android:orientation="horizontal">
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#FF9933"/>
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#FFFFFF"/>
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#138808"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="#0D1B4B" android:padding="24dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Step 3 of 7" android:textColor="#FF9933" android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Housing &amp; Infrastructure" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Living conditions and amenities" android:textColor="#99FFFFFF" android:textSize="13sp" android:layout_marginTop="4dp"/>
        <ProgressBar android:layout_width="match_parent" android:layout_height="4dp"
            style="?android:attr/progressBarStyleHorizontal"
            android:progress="42" android:progressTint="#FF9933"
            android:progressBackgroundTint="#33FFFFFF" android:layout_marginTop="16dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="#FFFFFF" android:padding="20dp" android:elevation="2dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="HOUSE TYPE" android:textColor="#757575" android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <Spinner android:id="@+id/spinnerHouseType" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:background="@drawable/input_bg"
                    android:padding="12dp" android:layout_marginBottom="20dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="OWNERSHIP" android:textColor="#757575" android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <Spinner android:id="@+id/spinnerOwnership" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:background="@drawable/input_bg"
                    android:padding="12dp" android:layout_marginBottom="20dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="TOILET TYPE" android:textColor="#757575" android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <Spinner android:id="@+id/spinnerToilet" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:background="@drawable/input_bg"
                    android:padding="12dp" android:layout_marginBottom="20dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DRINKING WATER SOURCE" android:textColor="#757575" android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <Spinner android:id="@+id/spinnerDrinkingWater" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:background="@drawable/input_bg"
                    android:padding="12dp" android:layout_marginBottom="20dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ELECTRICITY SOURCE" android:textColor="#757575" android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <Spinner android:id="@+id/spinnerElectricity" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:background="@drawable/input_bg"
                    android:padding="12dp" android:layout_marginBottom="20dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="COOKING FUEL" android:textColor="#757575" android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <Spinner android:id="@+id/spinnerCookingFuel" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:background="@drawable/input_bg"
                    android:padding="12dp" android:layout_marginBottom="20dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="NUMBER OF ROOMS" android:textColor="#757575" android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etNumRooms" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="e.g. 3"
                    android:inputType="number" android:background="@drawable/input_bg"
                    android:padding="12dp" android:layout_marginBottom="20dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="INTERNET ACCESS" android:textColor="#757575" android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <Spinner android:id="@+id/spinnerInternet" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:background="@drawable/input_bg"
                    android:padding="12dp" android:layout_marginBottom="24dp"/>

                <Button android:id="@+id/btnNext" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="NEXT → FAMILY"
                    android:padding="16dp" android:backgroundTint="#1E88E5"
                    android:textColor="#FFFFFF" android:textStyle="bold"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>